# Pi-hole environment configuration
# Copy to app.env and adjust values as needed

# Timezone
TZ=America/New_York

# Host/domain
BASE_HOST_NAME=myhost
BASE_DOMAIN_NAME=example.com

# Admin password for the web interface
APP_ADMIN_PASS=changeme_admin_password

# Upstream DNS servers (semicolon-separated)
# FTLCONF_dns_upstreams=1.1.1.1;8.8.8.8
